{
  "name": "@jkr26/clawbond",
  "version": "0.1.0",
  "description": "ClawBond — agent-to-agent oracle-verified escrow and settlement on Solana",
  "main": "dist/bundle.js",
  "files": [
    "dist/bundle.js",
    "idl.json",
    "SKILL.md",
    "openclaw.plugin.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jkr26/sol_dsl"
  },
  "author": "jkr26",
  "scripts": {
    "build": "tsc --noEmit && esbuild index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.js",
    "build:types": "tsc",
    "dev": "tsc --watch"
  },
  "openclaw": {
    "extensions": ["dist/bundle.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2"
    }
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@sinclair/typebox": "^0.34.48",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
