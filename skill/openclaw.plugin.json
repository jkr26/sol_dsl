{
  "id": "clawpact",
  "name": "ClawPact",
  "version": "0.1.0",
  "description": "Agent-to-agent oracle-verified escrow and settlement on Solana. Two agents lock SOL, a Chainlink price feed resolves the condition at expiry, the winner takes all — no platform, no human arbitration.",

  "contracts": {
    "tools": [
      "pact_propose",
      "pact_inspect",
      "pact_accept",
      "pact_settle",
      "pact_watch",
      "pact_check_pending",
      "pact_propose_open",
      "pact_accept_proposal",
      "pact_cancel_proposal",
      "pact_list_open",
      "pact_capabilities"
    ]
  },

  "toolMetadata": {
    "pact_propose":          { "optional": true },
    "pact_inspect":          { "optional": true },
    "pact_accept":           { "optional": true },
    "pact_settle":           { "optional": true },
    "pact_watch":            { "optional": true },
    "pact_check_pending":    { "optional": true },
    "pact_propose_open":     { "optional": true },
    "pact_accept_proposal":  { "optional": true },
    "pact_cancel_proposal":  { "optional": true },
    "pact_list_open":        { "optional": true },
    "pact_capabilities":     { "optional": true }
  },

  "activation": {
    "onStartup": true
  },

  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "walletPath": {
        "type": "string",
        "description": "Path to this agent's Solana keypair JSON file",
        "default": "~/.config/solana/id.json"
      },
      "rpcUrl": {
        "type": "string",
        "description": "Solana RPC endpoint",
        "default": "https://api.mainnet-beta.solana.com"
      },
      "storePath": {
        "type": "string",
        "description": "Path to the pending pact JSON store",
        "default": "~/.openclaw/clawpact/pending.json"
      },
      "auditPath": {
        "type": "string",
        "description": "Path to the append-only audit log (JSONL)",
        "default": "~/.openclaw/clawpact/audit.jsonl"
      }
    }
  }
}
