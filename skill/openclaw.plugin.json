{
  "id": "clawbond",
  "name": "ClawBond",
  "version": "0.1.0",
  "description": "Agent-to-agent oracle-verified escrow and settlement on Solana. Two agents lock SOL, a Chainlink price feed resolves the condition at expiry, the winner takes all — no platform, no human arbitration.",
  "entry": "dist/bundle.js",

  "contracts": {
    "tools": [
      "bond_propose",
      "bond_inspect",
      "bond_accept",
      "bond_settle",
      "bond_watch",
      "bond_check_pending",
      "bond_propose_open",
      "bond_accept_proposal",
      "bond_cancel_proposal",
      "bond_list_open",
      "bond_capabilities",
      "work_bond_create",
      "work_bond_join",
      "work_bond_complete",
      "work_bond_fail",
      "work_bond_expire",
      "work_bond_list"
    ]
  },

  "toolMetadata": {
    "bond_propose":          { "optional": true },
    "bond_inspect":          { "optional": true },
    "bond_accept":           { "optional": true },
    "bond_settle":           { "optional": true },
    "bond_watch":            { "optional": true },
    "bond_check_pending":    { "optional": true },
    "bond_propose_open":     { "optional": true },
    "bond_accept_proposal":  { "optional": true },
    "bond_cancel_proposal":  { "optional": true },
    "bond_list_open":        { "optional": true },
    "bond_capabilities":     { "optional": true },
    "work_bond_create":      { "optional": true },
    "work_bond_join":        { "optional": true },
    "work_bond_complete":    { "optional": true },
    "work_bond_fail":        { "optional": true },
    "work_bond_expire":      { "optional": true },
    "work_bond_list":        { "optional": true }
  },

  "activation": {
    "onStartup": true
  },

  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "walletPath": {
        "type": "string",
        "description": "Path to this agent's Solana keypair JSON file",
        "default": "~/.config/solana/id.json"
      },
      "rpcUrl": {
        "type": "string",
        "description": "Solana RPC endpoint",
        "default": "https://api.mainnet-beta.solana.com"
      },
      "storePath": {
        "type": "string",
        "description": "Path to the pending bond JSON store",
        "default": "~/.openclaw/clawbond/pending.json"
      },
      "auditPath": {
        "type": "string",
        "description": "Path to the append-only audit log (JSONL)",
        "default": "~/.openclaw/clawbond/audit.jsonl"
      },
      "telemetryEndpoint": {
        "type": "string",
        "description": "Optional URL to receive anonymised tool-call events (tool name, success/fail, error type, timestamp). No wallet addresses or transaction data are sent. Omit to disable."
      },
      "posthogKey": {
        "type": "string",
        "description": "Optional PostHog project API key (from posthog.com). When set, events are sent to PostHog instead of telemetryEndpoint. Free tier is sufficient."
      }
    }
  }
}
